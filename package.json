{
  "name": "q2",
  "version": "0.1.0",
  "description": "Quaternary Quantization – LFM2.5 ONNX chat interface with embedding extraction",
  "type": "module",
  "engines": {
    "bun": ">=1.3.10"
  },
  "scripts": {
    "build": "bun build --outdir dist --target browser --sourcemap=linked src/app.ts src/worker.ts",
    "dev": "bun build --watch --outdir dist --target browser --sourcemap=linked src/app.ts src/worker.ts",
    "typecheck": "bun x tsc --noEmit",
    "test": "vitest run --coverage",
    "test:browser": "vitest run --browser",
    "coverage": "vitest run --coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devlux76/q2.git"
  },
  "keywords": ["llm", "onnx", "transformers", "wasm", "quaternary-quantization"],
  "license": "MIT",
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@vitest/coverage-c8": "^0.33.0",
    "@vitest/coverage-istanbul": "^4.1.0",
    "jsdom": "^29.0.0",
    "typescript": "latest",
    "vitest": "^4.1.0",
    "@vitest/browser-playwright": "^4.1.0",
    "playwright": "^1.46.0"
  },
  "dependencies": {
    "@huggingface/transformers": "latest"
  }
}
